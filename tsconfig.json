{
  "compilerOptions": {
    "strict": true,
    "outDir": "./dist/",
    "noImplicitAny": true,
    "module": "commonjs",
    "target": "es6",
    "lib": ["dom", "es2019"],
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "eventemitter3": ["src/libs/eventemitter3.js"]
    }
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "typeRoots": ["./node_modules/@types", "./types"]
    }
  },
  "include": [
    "src/**/*",
    "types/**/*.d.ts",
    "pathMap.ts",
    "eslint.config.mjs",
    "tailwind.config.ts",
    "webpack.config.ts",
    "public/pixi/pixi.js",
    "public/pixi/pixi-spine-3.8.js"
  ]
}
