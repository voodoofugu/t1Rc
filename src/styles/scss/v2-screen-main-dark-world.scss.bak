                    }
                    .selected-angel-box {
                        position: absolute;
                        top: 88px;
                        left: 143px;
                        background: #423061;
                        border-radius: 14px;
                        box-shadow: 0 0 4px 1px rgba(255, 255, 255, 0.15);
                        width: 484px;
                        height: 336px;
                        .angel-card-box {
                            width: 338px;
                            height: 323px;
                            background: linear-gradient(
                                159.21deg,
                                #9f7c47 1.39%,
                                #e9be88 35.56%,
                                #946f3f 70.08%,
                                #cca36f 84.6%,
                                #b38952 98.01%
                            );
                            transition: ease-in-out 0.1s;
                            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.4);
                            border-radius: 8px;
                            position: absolute;
