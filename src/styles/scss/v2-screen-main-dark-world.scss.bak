                        align-items: center;
                        .supheros-bonus-wrap {
                            background: #373e56;
                            border-radius: 6px;
                            color: #99e6f9;
                            font-weight: 700;
                            font-size: 15px;
                            line-height: 32px;
                            text-shadow: 0 1px 1px #000;
                            padding: 0 10px;
                            margin: 0 4px;
                            display: flex;
                            box-shadow: inset 0 0 0 1px #c19863,
                                inset 0 11px 0px rgba(255, 255, 255, 0.08),
                                inset 0 2px 1px #3d3737;
                            .supheros-bonus-value {
                                display: inline-block;
                                color: #fff493;
                                font-size: 18px;
                                min-width: 44px;
                                text-align: center;
                                margin-left: 10px;
                                &:after {
                                    content: "%";
                                }
