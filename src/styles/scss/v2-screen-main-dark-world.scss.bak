                            transform: scaleX(-1);
                            box-shadow: inset -14px 0 0 #423061;
                            &::-webkit-scrollbar-track {
                                -webkit-box-shadow: inset 0 0 6px
                                    rgba(0, 0, 0, 0.8);
                                border-radius: 8px;
                            }
                            &::-webkit-scrollbar {
                                width: 8px;
