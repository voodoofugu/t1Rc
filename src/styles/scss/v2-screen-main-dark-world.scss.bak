                                    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
                                    .hero-avatar {
                                        width: 90px;
                                        height: 103px;
                                        position: absolute;
                                        top: 4px;
                                        left: 4px;
                                        @include prefix(border-radius, 4px);
