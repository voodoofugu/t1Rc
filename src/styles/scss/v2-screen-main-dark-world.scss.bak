                                top: 7px;
                                border-radius: 5px;
                                box-shadow: 0 0 0 1px #734407,
                                    0px 0px 3px rgba(0, 0, 0, 0.4);
                                overflow: hidden;
                                display: flex;
                                justify-content: center;
                                img {
                                    width: auto;
                                    height: 160%;
                                }
                                .b-fs {
                                    display: inline-block;
                                    width: 35px;
                                    height: 35px;
                                    position: absolute;
                                    top: 5px;
                                    right: 5px;
                                    background: none;
                                    background-image: url(chahge-fullscr.png);
                                    background-size: 100%;
                                    cursor: pointer;
                                    &:hover {
                                        filter: brightness(1.1);
                                    }
                                    &:active {
                                        transform: scale(0.96);
                                    }
                                }
                            }
                            .img-wrap.lock {
                                img {
                                    filter: grayscale(1) blur(2px);
                                }
                                .b-fs {
                                    display: none;
                                }
                                &:after {
                                    content: "";
                                    width: 70px;
                                    height: 70px;
                                    position: absolute;
                                    top: 50%;
                                    left: 50%;
                                    transform: translate(-50%, -50%);
                                    background-image: url(v2-lock-ic.png);
                                    background-size: 100%;
                                }
                            }
                            .info-box {
                                width: 324px;
                                height: 118px;
                                margin: auto;
                                position: relative;
                                top: 198px;
                                background: rgba(0, 0, 0, 0.4);
                                border-radius: 0 0 4px 4px;
                                color: #fff;
                                text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);
                                .stars-box {
                                    width: 100%;
                                    height: 28px;
                                    background: rgba(255, 255, 255, 0.4);
                                    display: flex;
                                    justify-content: center;
                                    .star {
                                        margin-top: 1px;
                                        width: 26px;
                                        height: 26px;
                                        background-image: url(star-inactive-bg.png);
                                        background-repeat: no-repeat;
                                        background-position: center;
                                        background-size: cover;
                                    }
                                    .star.active {
                                        background-image: url(star-active-bg.png);
                                    }
                                }
                                .text-box {
                                    display: flex;
                                    .text1,
                                    .text2 {
                                        font-size: 14px;
                                        line-height: 17px;
                                        width: 162px;
                                        text-align: center;
                                        .buff-level-info,
                                        .buff-bonus-info {
                                            .level-value,
                                            .buff-value {
                                                display: inline-block;
                                            }
                                        }
                                    }
                                }
                            }
                            .angel-card-progress-bar-wrap {
                                width: 189px;
                                height: 26px;
                                background: linear-gradient(
                                    180deg,
                                    #31302c 0%,
                                    #5d5b55 63.91%,
                                    #3d3b35 100%
                                );
                                border-radius: 5px;
                                position: absolute;
                                left: 50%;
                                transform: translateX(-50%);
                                top: 280px;
                                color: #fff;
                                text-shadow: 0 1px 2px rgba(0, 0, 0, 1);
                                .progress {
                                    position: absolute;
                                    width: 187px;
                                    height: 24px;
                                    left: 1px;
                                    top: 1px;
                                    border-radius: 4px;
                                    overflow: hidden;
                                    .fulfilled {
                                        height: 100%;
                                        background: linear-gradient(
                                            90deg,
                                            #86ea21 0%,
                                            #0dbf34 100%
                                        );
                                        border-radius: 4px;
                                        box-shadow: inset 0 2px 4px
                                                rgba(0, 0, 0, 0.25),
                                            inset 0 10px 0
                                                rgba(255, 255, 255, 0.3);
                                    }
                                }
                                .value {
                                    position: absolute;
                                    display: flex;
                                    left: 50%;
                                    top: 50%;
                                    transform: translate(-50%, -50%);
                                    text-shadow: 0px 1px 4px rgba(0, 0, 0, 0.75);
                                    line-height: 20px;
                                    white-space: nowrap;
                                    .from {
                                        margin-left: 4px;
                                    }
                                    .to {
                                        &:before {
                                            content: "/";
                                        }
                                    }
                                }
                            }
                            .arrow-box-all {
                                width: 292px;
                                position: absolute;
                                bottom: 13px;
                                left: 50%;
                                transform: translateX(-50%);
                                display: flex;
                                justify-content: space-between;
                                .btn-scroll-card {
                                    width: 32px;
                                    height: 32px;
                                    border-radius: 100%;
                                    cursor: pointer;
                                    background: linear-gradient(
                                        180deg,
                                        #fff789 0%,
                                        #ffdd7c 100%
                                    );
                                    box-shadow: 0 0 0 1px #524237,
                                        0px 2px 4px rgba(0, 0, 0, 0.45),
                                        inset 0px -4px 0px rgba(0, 0, 0, 0.2);
                                    position: relative;
                                    &:hover {
                                        filter: brightness(1.1);
                                    }
                                    &:active {
                                        transform: scale(0.96);
                                    }
                                    &:before {
                                        content: "";
                                        width: 14px;
                                        height: 22px;
                                        background-image: url(rating-arrow.png);
                                        background-size: cover;
                                        position: absolute;
                                        top: 4px;
                                        left: 8px;
                                    }
                                }
                                .btn-scroll-card.right {
                                    &:before {
                                        transform: scaleX(-1);
                                        left: unset;
                                        right: 8px;
                                    }
                                }
                            }
                            .color-btn.get-angel {
                                display: none;
                                position: absolute;
                                left: 50%;
                                top: 50%;
                                transform: translate(-50%, -50%);
                                width: 118px;
                                height: 46px;
                            }
                        }
                        .angel-card-box.lock {
                            .info-box {
                                height: 76px;
                                top: 240px;
                            }
                            .text-box,
                            .arrow-box-all,
                            .img-wrap .b-fs {
                                display: none;
                            }
                            .color-btn.get-angel {
                                display: block;
                            }
                            .img-wrap {
                                img {
                                    filter: grayscale(1);
                                }
                            }
                        }
                        .progress-box {
                            position: absolute;
                            left: 351px;
                            top: 6px;
                            width: 126px;
                            height: 323px;
                            border-radius: 8px;
                            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.4);
                            background: linear-gradient(
                                0deg,
                                #ffe199,
                                #f4c657 18%,
                                #ffe199 60%,
                                #f4c657 85%,
                                #ffe199
                            );
                            .selected-angel-icons-box {
                                display: flex;
                                flex-direction: column-reverse;
                                justify-content: space-evenly;
                                height: calc(100% - 7px);
                                padding: 3.5px;
                                .angel-avatar-box {
                                    width: 72px;
                                    height: 72px;
                                    background: linear-gradient(
                                        159.21deg,
                                        #9f7c47 1.39%,
                                        #e9be88 35.56%,
                                        #946f3f 70.08%,
                                        #cca36f 84.6%,
                                        #b38952 98.01%
                                    );
                                    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.5);
                                    border-radius: 6px;
                                    margin: 3.5px;
                                    display: flex;
                                    justify-content: center;
                                    align-items: center;
                                    position: relative;
                                    cursor: pointer;
                                    &:hover {
                                        filter: brightness(110%);
                                    }
                                    &:active {
                                        transform: scale(0.98);
                                    }
                                    .angel-avatar-wrap {
                                        width: 64px;
                                        height: 64px;
                                        border-radius: 4px;
                                        overflow: hidden;
                                        box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.3);
                                        .angel-avatar {
                                            width: 100%;
                                        }
                                    }
                                }
                                .angel-avatar-box.lock {
                                    cursor: unset;
                                    &:active {
                                        transform: scale(1);
                                    }
                                    &:after {
                                        content: "";
                                        width: 50px;
                                        height: 50px;
                                        position: absolute;
                                        top: 50%;
                                        left: 50%;
                                        transform: translate(-50%, -50%);
                                        background-image: url(v2-lock-ic.png);
                                        background-size: 100%;
                                    }
                                    .angel-avatar-wrap {
                                        filter: grayscale(1) brightness(0.6);
                                    }
                                }
                            }
                            .selected-angel-progress-bar-wrap {
                                width: 311px;
                                height: 34px;
                                position: absolute;
                                top: 145px;
                                left: -52px;
                                background: linear-gradient(
                                    #2b2a26 0%,
                                    #585751 52.58%,
                                    #2b2a26 99.96%
                                );
                                box-shadow: inset 0 0 0 1px #404b4e;
                                border-radius: 6px;
                                transform: rotate(-90deg);
                                .progress {
                                    position: absolute;
                                    width: 307px;
                                    height: 30px;
                                    left: 2px;
                                    top: 2px;
                                    border-radius: 4px;
                                    overflow: hidden;
                                    .fulfilled {
                                        height: 100%;
                                        background: linear-gradient(
                                            #1e47ab 0%,
                                            #5f93ff 23.96%,
                                            #b1cbff 49.48%,
                                            #5f93ff 79.69%,
                                            #1e47ab 100%
                                        );
                                        border-radius: 4px;
                                    }
                                }
                                .progress-level-wrap {
                                    transform: rotate(90deg);
                                    position: absolute;
                                    top: -139px;
                                    left: 138px;
                                    height: 311px;
                                    display: flex;
                                    flex-direction: column-reverse;
                                    justify-content: space-evenly;
                                    .progress-level {
                                        height: calc(100% / 4);
                                        .progress-level-txt {
                                            width: 36px;
                                            height: 16px;
                                            background: linear-gradient(
                                                89.99deg,
                                                #d2a264 0%,
                                                #653b05 7.29%,
                                                #ddac70 51.04%,
                                                #653b05 94.78%,
                                                #d2a264 99.99%
                                            );
                                            box-shadow: 0px 1px 1px
                                                    rgba(0, 0, 0, 0.4),
                                                inset 0 1px 0
                                                    rgba(255, 255, 255, 0.2);
                                            color: #fff;
                                            text-align: center;
                                            line-height: 16px;
                                            font-size: 12px;
                                            text-shadow: 0 1px 2px #000,
                                                0 0 4px rgba(0, 0, 0, 0.6);
                                        }
                                    }
                                }
                            }
                        }
                    }
                    .angels-heros-box-wrap {
                        position: absolute;
                        top: 88px;
                        left: 656px;
                        padding: 0 24px;
                        .angels-heros-box {
                            background: #423061;
                            border-radius: 14px;
                            box-shadow: 0 0 4px 1px rgba(255, 255, 255, 0.15);
                            width: 354px;
                            height: 328px;
                            padding: 4px;
                            .hero-page-wrapper {
                                display: flex !important;
                                flex-wrap: wrap;
                            }
                            .hero-btn-card-add {
                                width: 104px;
                                height: 128px;
                                margin: 18px 7px;
                                position: relative;
                                @include prefix(border-radius, 10px);
                                box-shadow: 0px 1px 2px rgba(0, 0, 0, 0.4);
                                background: linear-gradient(
                                    155.68deg,
                                    #4675d0 6.11%,
                                    #b0c6ff 53.31%,
                                    #2457da 65.64%,
                                    #a3bcff 81.23%,
                                    #4675d0 97.65%
                                );
                                display: flex;
                                justify-content: center;
                                align-items: center;
                                &:before {
                                    content: "";
                                    width: 96px;
                                    height: 120px;
                                    position: absolute;
                                    background: radial-gradient(
                                        66.3% 50% at 50% 50%,
                                        #af93ff 0%,
                                        #2f157a 100%
                                    );
                                    border-radius: 8px;
                                }
                                .color-btn.add {
                                    width: 38px;
                                    height: 38px;
                                    background: linear-gradient(
                                        180deg,
                                        #c5d5ff 0%,
                                        #97b6ff 15.63%,
                                        #bbd0ff 38.54%,
                                        #74a3ff 62.5%,
                                        #3766e0 100%
                                    );
                                    border: 2px solid #ffd18e;
                                    border-radius: 9px;
                                    .color-btn-text {
                                        color: #442768;
                                        font-size: 30px;
                                        text-shadow: 0 1px 2px #fff;
                                    }
                                }
                            }
                            .hero-card {
                                width: 110px;
                                height: 156px;
                                position: relative;
                                display: inline-block;
                                background: rgb(99, 72, 145);
                                box-shadow: 0px 1px 2px rgba(0, 0, 0, 0.4);
                                margin: 4px;
                                @include prefix(border-radius, 10px);
                                &:hover {
                                    background: rgb(112, 82, 163);
                                }
                                .hero-avatar-box {
                                    width: 98px;
                                    height: 98px;
                                    position: absolute;
                                    top: 6px;
                                    left: 6px;
                                    @include prefix(border-radius, 6px);
                                    background: linear-gradient(
                                        155.68deg,
                                        #4675d0 6.11%,
                                        #b0c6ff 53.31%,
                                        #2457da 65.64%,
                                        #a3bcff 81.23%,
                                        #4675d0 97.65%
                                    );
                                    box-shadow: 0px 1px 1px rgba(0, 0, 0, 0.35);
                                    .hero-avatar-wrap {
                                        position: absolute;
                                        top: 4px;
                                        left: 4px;
                                        width: 90px;
                                        height: 90px;
                                        border-radius: 6px;
                                        overflow: hidden;
                                        display: flex;
                                        box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.3);
                                        .hero-avatar {
                                            width: auto;
                                            height: 103px;
                                        }
                                    }
                                    .sh2-icon-forgirl {
                                        width: 25px;
                                        height: 32px;
                                        position: absolute;
                                        top: 0px;
                                        left: 2px;
                                        img {
                                            width: 25px;
                                        }
                                    }
                                    .hero-level-box {
                                        position: absolute;
                                        top: 2px;
                                        right: 2px;
                                        background: linear-gradient(
                                            270deg,
                                            #30269e 0%,
                                            #6459e2 51.56%,
                                            #30269e 100%
                                        );
                                        width: 56px;
                                        height: 18px;
                                        color: #c6f4ff;
                                        font-size: 12px;
                                        font-weight: bold;
                                        text-transform: uppercase;
                                        line-height: 18px;
                                        text-shadow: 0 1px 2px
                                            rgba(0, 0, 0, 0.35);
                                        border-radius: 4px;
                                        padding-left: 5px;
                                        .hero-level {
                                            color: #fff493;
                                            display: inline-block;
                                            font-size: 14px;
                                            font-weight: bold;
                                            line-height: 18px;
                                            text-align: right;
                                            position: absolute;
                                            right: 5px;
                                        }
                                    }
                                    .hero-dps-box {
                                        width: 85px;
                                        top: 78px;
                                        border-radius: 0 0 3px 3px;
                                        background: linear-gradient(
                                            90deg,
                                            #0a3c60 0%,
                                            #1e70aa 51.04%,
                                            #0a3c60 100%
                                        );
                                        height: 16px;
                                        position: absolute;
                                        right: 4px;
                                        box-shadow: inset 0 10px 0
                                                rgba(255, 255, 255, 0.1),
                                            0 1px 1px rgba(0, 0, 0, 0.15);
                                        color: #c6f4ff;
                                        font-size: 12px;
                                        font-weight: bold;
                                        text-transform: uppercase;
                                        line-height: 16px;
                                        padding-left: 5px;
                                        text-shadow: 0 1px 2px
                                            rgba(0, 0, 0, 0.35);
                                        .hero-dps {
                                            width: 50px;
                                            height: auto;
                                            position: absolute;
                                            right: 5px;
                                            top: 0;
                                            color: #fff493;
                                            font-size: 14px;
                                            line-height: 18px;
                                            text-align: right;
                                            text-transform: none;
                                        }
                                    }
                                }
                                .color-btn.green {
                                    width: 98px;
                                    position: absolute;
                                    top: 109px;
                                    right: 6px;
                                    .color-btn-text {
                                        .gold {
                                            text-transform: none;
                                            color: #222222;
                                            text-shadow: 0 0 0;
                                            font-size: 16px;
                                            top: 2px;
                                            position: relative;
                                            .f-gold {
                                                &:before {
                                                    content: "";
                                                    width: 18px;
                                                    height: 18px;
                                                    position: relative;
                                                    display: inline-block;
                                                    background-image: url(ic-yellow-butil.png);
                                                    background-size: 100%;
                                                    margin: 0 4px 0 4px;
                                                    vertical-align: middle;
                                                    top: -2px;
                                                }
                                            }
                                        }
                                    }
                                    .color-btn-text {
                                        top: 0;
                                    }
                                    &:active {
                                        box-shadow: inset 0 -2px 0px rgba(0, 0, 0, 0.2),
                                            inset 0 2px 2px rgba(0, 0, 0, 0.2);
                                        .color-btn-text {
                                            top: 1px;
                                        }
                                    }
                                    &:hover {
                                        filter: brightness(110%);
                                        -webkit-filter: brightness(110%);
                                    }
                                }
                            }
                        }
                        .btn-scroll-dark {
                            position: absolute;
                            top: 50%;
                            transform: translateY(-50%);
                            width: 18px;
                            height: 72px;
                            background-image: url(darkworld-slider-active.png);
                            background-size: cover;
                            background-repeat: no-repeat;
                            background-position: center;
                            cursor: pointer;
                            &:hover {
                                filter: brightness(120%);
                            }
                            &:active {
                                transform: translateY(-50%) scale(0.94);
                            }
                        }
                        .btn-scroll-dark.left {
                            left: -28px;
                            transform: translateY(-50%) scaleX(-1);
                        }
                        .btn-scroll-dark.right {
                            right: -28px;
                        }
                        .btn-scroll-dark.slick-disabled {
                            background-image: url(darkworld-slider-inactive.png);
                            pointer-events: none;
                        }
                        .x2-btn {
                            width: 62px;
                            height: 26px;
                            position: absolute;
                            display: inline-block;
                            background: linear-gradient(
                                180deg,
                                #938bc8 0%,
                                #4c4683 99.99%
                            );
                            @include prefix(border-radius, 6px);
                            right: 24px;
                            bottom: -34px;
                            box-shadow: inset 0 -4px 0 rgba(0, 0, 0, 0.25),
                                0 2px 4px rgba(0, 0, 0, 0.55);
                            cursor: pointer;
                            &:hover {
                                filter: brightness(110%);
                            }
                            .x2-btn-text {
                                color: #fff;
                                font-size: 16px;
                                font-weight: bold;
                                text-align: center;
                                position: relative;
                                top: 2px;
                                text-shadow: 0 1px 2px rgba(0, 0, 0, 0.25);
                            }
                            &:active {
                                pointer-events: none;
                                background: linear-gradient(
                                    180deg,
                                    #a99fee 0%,
                                    #6259b3 99.99%
                                );
                                box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.25),
                                    inset 0 -2px 0 rgba(0, 0, 0, 0.25),
                                    0 0 6px rgba(0, 0, 0, 0.25);
                                .x2-btn-text {
                                    top: 3px;
                                    color: #fff;
                                }
                            }
                        }
                    }
                    .angels-heros-box-wrap.lock {
                        .angels-heros-box {
                            .hero-btn-card-add,
                            .hero-card {
                                filter: grayscale(1);
                                pointer-events: none;
                            }
                        }
                        .x2-btn {
                            filter: grayscale(1);
                            pointer-events: none;
                        }
                    }
                    .supheros-bottom-content {
                        position: absolute;
                        top: 434px;
                        left: 50%;
                        transform: translateX(-50%);
                        background: #423061;
                        border-radius: 14px;
                        box-shadow: 0 0 4px 1px rgba, (255, 255, 255, 0.15);
                        width: auto;
                        height: 60px;
                        padding: 0 10px;
