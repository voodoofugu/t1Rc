                                #2867c5 49%,
                                #bee0ff 115.2%
                            );
                            box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.55),
                                inset 0px 0px 4px #000315;
                            border-radius: 6px;
                            display: flex;
