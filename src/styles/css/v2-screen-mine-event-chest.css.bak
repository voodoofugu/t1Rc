}
@keyframes JumpX {
  0% {
    transform: translate(0%, 0%) scale(1, 1);
  }
  10% {
    transform: translate(0%, 0%) scale(1.25, 0.75);
  }
  50% {
    transform: translate(0%, -20%) scale(1, 1);
  }
  55% {
    transform: translate(0%, -20%) rotate(15deg);
  }
  60% {
    transform: translate(0%, -20%) rotate(-15deg);
  }
  65% {
    transform: translate(0%, -20%) rotate(15deg);
  }
  70% {
    transform: translate(0%, -20%) rotate(-15deg);
  }
  90% {
    transform: translate(0%, 0%) scale(1.25, 0.75);
  }
  100% {
    transform: translate(0%, 0%) scale(1, 1);
  }
}

