@charset "UTF-8";
.v2-guildmap-name {
  transform: scale(0.88);
}

.v2-guildmap-info-box {
  width: 170px;
  height: 110px;
  position: absolute;
  left: 390px;
  bottom: 328px;
  z-index: 99999;
  opacity: 0.88;
  cursor: pointer;
}
.v2-guildmap-info-box .v2-guildmap-name {
  width: 170px;
  height: 36px;
  position: absolute;
  bottom: 16px;
  left: 0;
  background-image: url(img/wpck-ram1.png);
  background-size: 100%;
  background-repeat: no-repeat;
  color: #fff;
  font-size: 12px;
  font-weight: bold;
  text-transform: uppercase;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  text-align: center;
  line-height: 32px;
}
.v2-guildmap-info-box .v2-guildmap-lvl {
  width: 80px;
  height: 30px;
  position: absolute;
  bottom: 0px;
  left: 45px;
  background: linear-gradient(0deg, #ffe199 0%, #f4c657 18%, #ffe199 60%, #f4c557 85%, #ffe199 100%);
  -webkit-border-radius: 10px;
  -moz-border-radius: 10px;
  -ms-border-radius: 10px;
  -o-border-radius: 10px;
  border-radius: 10px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  color: #323232;
  font-size: 12px;
  font-weight: bold;
  text-transform: uppercase;
  text-shadow: 0 0 4px #fff0ae;
  text-align: center;
  line-height: 38px;
}
.v2-guildmap-info-box .v2-guildmap-notif {
  width: 24px;
  height: 24px;
  position: absolute;
  bottom: 32px;
  left: 0px;
  background-image: url(img/picmeh-ic-info.png);
  background-size: 100%;
  background-repeat: no-repeat;
}
.v2-guildmap-info-box .v2-guildmap-block {
  width: 40px;
  height: 60px;
  position: absolute;
  top: 0;
  left: 65px;
  background-image: url(img/tower-lock.png);
  background-size: 100%;
  background-repeat: no-repeat;
  display: none;
}
.v2-guildmap-info-box:hover {
  filter: brightness(1.1) contrast(1.1);
  opacity: 1;
}
.v2-guildmap-info-box.wheel {
  left: 390px;
  top: 328px;
}
.v2-guildmap-info-box.wheel:hover + .v2-guildmap-fortune {
  filter: brightness(1.1) contrast(1.1);
}
.v2-guildmap-info-box.shrine {
  left: 604px;
  top: 379px;
}
.v2-guildmap-info-box.shrine:hover + .v2-guildmap-shrine {
  filter: brightness(1.1) contrast(1.1);
}
.v2-guildmap-info-box.trophies {
  left: 109px;
  top: 367px;
}
.v2-guildmap-info-box.trophies:hover + .v2-guildmap-trophy {
  filter: brightness(1.1) contrast(1.1);
}
.v2-guildmap-info-box.hall {
  left: 430px;
  top: 57px;
  height: 210px;
  width: 210px;
}
.v2-guildmap-info-box.hall:hover + .v2-guildmap-guild-hall {
  filter: brightness(1.1) contrast(1.1);
}
.v2-guildmap-info-box.super {
  left: 42px;
  top: 83px;
  height: 210px;
  width: 210px;
}
.v2-guildmap-info-box.super:hover + .v2-guildmap-suphero {
  filter: brightness(1.1) contrast(1.1);
}
.v2-guildmap-info-box.wars {
  left: 242px;
  top: 188px;
  height: 182px;
  width: 172px;
}
.v2-guildmap-info-box.wars:hover + .v2-guildmap-alley3 {
  filter: brightness(1.1) contrast(1.1);
}
.v2-guildmap-info-box.tower {
  left: 810px;
  top: 81px;
}
.v2-guildmap-info-box.tower:hover + .v2-guildmap-darktower {
  filter: brightness(1.1) contrast(1.1);
}
.v2-guildmap-info-box.master {
  left: 637px;
  top: 162px;
}
.v2-guildmap-info-box.master:hover + .v2-guildmap-master {
  filter: brightness(1.1) contrast(1.1);
}
.v2-guildmap-info-box.clans {
  left: 937px;
  top: 162px;
}
.v2-guildmap-info-box.clans:hover + .v2-guildmap-gate {
  filter: brightness(1.1) contrast(1.1);
}
.v2-guildmap-info-box.gate {
  left: 515px;
  top: 230px;
}
.v2-guildmap-info-box.gate:hover + .v2-guildmap-alley1 {
  filter: brightness(1.1) contrast(1.1);
}
.v2-guildmap-info-box.warehouse {
  left: 757px;
  top: 258px;
}
.v2-guildmap-info-box.warehouse:hover + .v2-guildmap-warehouse {
  filter: brightness(1.1) contrast(1.1);
}
.v2-guildmap-info-box.mine {
  left: 910px;
  top: 341px;
}
.v2-guildmap-info-box.mine:hover + .v2-guildmap-mine {
  filter: brightness(1.1) contrast(1.1);
}
.v2-guildmap-info-box.wild {
  left: 932px;
  top: 38px;
  cursor: default;
}
.v2-guildmap-info-box.wild:hover + .v2-guildmap-wilderness {
  filter: brightness(1.1) contrast(1.1);
}

body .main .left-side {
  width: 620px;
  height: 555px;
  position: absolute;
  left: 5px;
  bottom: 5px;
}
body .main .left-side .tabs-all-box {
  width: 500px;
  height: 40px;
  position: absolute;
  top: 0;
  left: 0;
  font-size: 0;
}
body .main .left-side .tabs-all-box .tabs-all {
  width: 118px;
  height: 40px;
  position: relative;
  top: 0;
  left: 0;
  display: inline-block;
  margin: 0 2px 0 0;
  cursor: pointer;
  background-color: #9c8b7c;
  -webkit-border-radius: 24px 24px 0 0;
  -moz-border-radius: 24px 24px 0 0;
  -ms-border-radius: 24px 24px 0 0;
  -o-border-radius: 24px 24px 0 0;
  border-radius: 24px 24px 0 0;
}
body .main .left-side .tabs-all-box .tabs-all:before {
  content: "";
  width: 110px;
  height: 36px;
  position: absolute;
  top: 4px;
  left: 4px;
  background-color: #544746;
  -webkit-border-radius: 20px 20px 0 0;
  -moz-border-radius: 20px 20px 0 0;
  -ms-border-radius: 20px 20px 0 0;
  -o-border-radius: 20px 20px 0 0;
  border-radius: 20px 20px 0 0;
  box-shadow: inset 0 4px 6px rgba(0, 0, 0, 0.15);
}
body .main .left-side .tabs-all-box .tabs-all .tabs-name {
  width: 60px;
  height: 40px;
  position: absolute;
  right: 14px;
  color: #fff;
  font-weight: bold;
  font-size: 12px;
  line-height: 44px;
  text-align: center;
}
body .main .left-side .tabs-all-box .tabs-all .tabs-pic {
  width: 50px;
  height: 32px;
  position: absolute;
  top: 5px;
  left: 5px;
}
body .main .left-side .tabs-all-box .tabs-all .tabs-pic img {
  width: 50px;
}
body .main .left-side .tabs-all-box .tabs-all.selected:before {
  content: "";
  background-color: #9c8b7c;
}
body .main .left-side .left-panel {
  width: 620px;
  height: 515px;
  position: absolute;
  left: 0;
  top: 40px;
}
body .main .left-side .left-panel:before {
  content: "";
  width: 620px;
  height: 5px;
  position: absolute;
  top: 0;
  left: 0;
  background-color: #9c8b7c;
  z-index: 999;
}
body .main .left-side .left-panel.wide {
  width: 1106px;
}
body .main .left-side .left-panel.wide:before {
  content: "";
  width: 1102px;
}
body .main .left-side .left-panel.wide .tab-panel-box.guild-main {
  width: 1098px;
  height: 511px;
  position: absolute;
  top: 0;
  left: 0;
  border: solid 4px #9c8b7c;
  border-top: none;
  box-shadow: inset 0 0 7px #5f4f4e;
  background-color: red;
}
body .main .left-side .left-panel.wide .tab-panel-box.guild-main .guild-map-box-all {
